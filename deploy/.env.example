# TriCore Agent v1.0 — 环境变量模板
# 复制为 .env 并填写实际值

# ── 必需: LLM API Key ──
LLM_API_KEY=sk-your-api-key-here

# ── LLM Provider 配置 ──
LLM_PROVIDER=deepseek
LLM_MODEL=

# ── 多Provider（可选） ──
# ═══ 国内 ═══
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
BAICHUAN_API_KEY=
STEPFUN_API_KEY=
BYTEDANCE_API_KEY=
BAIDU_API_KEY=
TENCENT_API_KEY=
IFLYTEK_API_KEY=
SILICONFLOW_API_KEY=
# ═══ 国际 ═══
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
LLAMA_API_KEY=
COHERE_API_KEY=
AI21_API_KEY=
REKA_API_KEY=
PERPLEXITY_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=

# ── 安全 ──
TRICORE_ADMIN_PASSWORD=change-me-in-production
TRICORE_API_TOKEN=
# JWT签名密钥 (生产环境必须设置，至少32字符随机字符串)
# 未设置时系统会自动生成并存储到 data/.jwt_secret（0600权限）
TRICORE_JWT_SECRET=

# ── 网络 ──
TRICORE_API_PORT=3721
TRICORE_HEALTH_PORT=3722
TRICORE_ALLOW_LAN=0

# ── 性能 ──
TRICORE_TICK_CONCURRENCY=2
TRICORE_HOURLY_BUDGET=50000
TRICORE_MEMORY_LIMIT=1G
TRICORE_CPU_LIMIT=2.0
TRICORE_MEMORY_RESERVE=256M
TRICORE_CPU_RESERVE=0.5

# ── 持久化 ──
TRICORE_PERSIST_ENABLED=true
TRICORE_CONFIG_DIR=./data/config

# ── 日志 ──
LOG_MAX_SIZE=20m
LOG_MAX_FILES=5

# ── 监控（可选） ──
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=tricore-grafana-change-me

# ═══════════════════════════════════════
# v3.1 新增: 全流程启动自检
# ═══════════════════════════════════════
TRICORE_SELFCHECK_ENABLED=true
TRICORE_SELFCHECK_TIMEOUT=180000

# ═══════════════════════════════════════
# v4.0 新增: WebSocket 实时通信
# ═══════════════════════════════════════
TRICORE_WS_ENABLED=true
TRICORE_WS_PORT=3723
TRICORE_WS_HEARTBEAT=30000
TRICORE_WS_RECONNECT_TIMEOUT=10000

# ═══════════════════════════════════════
# v4.0 新增: Web搜索配置
# ═══════════════════════════════════════
TRICORE_SEARCH_API=duckduckgo
TRICORE_SEARCH_API_KEY=
TRICORE_SEARCH_TIMEOUT=10000

# ═══════════════════════════════════════
# v4.0 新增: Dashboard 仪表盘
# ═══════════════════════════════════════
TRICORE_DASHBOARD_PORT=3724
TRICORE_DASHBOARD_ENABLED=true

# ═══════════════════════════════════════
# v4.0 新增: 国际化
# ═══════════════════════════════════════
TRICORE_LOCALE=zh-CN

# ═══════════════════════════════════════
# v4.0 新增: 内容安全过滤
# ═══════════════════════════════════════
TRICORE_CONTENT_FILTER_ENABLED=true
TRICORE_CONTENT_FILTER_MODE=standard

# ═══════════════════════════════════════
# v4.0 新增: ANN向量索引
# ═══════════════════════════════════════
TRICORE_ANN_INDEX_TYPE=flat
TRICORE_ANN_INDEX_PATH=./data/ann_index

# ═══════════════════════════════════════
# v4.0 新增: 整合重试
# ═══════════════════════════════════════
TRICORE_CONSOLIDATION_RETRY_MAX=3
TRICORE_CONSOLIDATION_RETRY_BASE_DELAY=30000

# ═══════════════════════════════════════
# v4.0 新增: 分层缓存
# ═══════════════════════════════════════
TRICORE_LAYERED_CACHE_TTL=5000
